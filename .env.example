# Copy this file to .env or run scripts/setup-env.ps1.

SA_PASSWORD=ChangeThis!12345
DB_NAME=AppTemplateDb

# Frontend build-time API URL.
# Local Docker through nginx: http://localhost/api
# Production: https://example.com/api
NEXT_PUBLIC_API_URL=http://localhost/api

# CORS origins accepted by the backend.
FRONTEND_ORIGIN=http://localhost
LOCAL_FRONTEND_ORIGIN=http://localhost:3000

# Host ports mapped to the nginx container.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Use /etc/letsencrypt on a production Linux host.
LETSENCRYPT_PATH=./nginx/letsencrypt
